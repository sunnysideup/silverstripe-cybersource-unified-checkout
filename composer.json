{
  "name": "sunnysideup/cybersource-unified-checkout",
  "description": "Implements the cybersource unified checkout for e-commerce",
  "type": "silverstripe-vendormodule",
  "keywords": [
    "cybersource",
    "unified checkout",
    "payment",
    "visa",
    "mastercard",
    "amex",
    "google pay",
    "apple pay"
  ],
  "license": "BSD-3-Clause",
  "require": {
    "silverstripe/framework": "^5.0",
    "silverstripe/admin": "^2.0"
  },
  "require-dev": {
    "sunnysideup/sswebpack_engine_only": "5.x-dev",
    "silverleague/ideannotator": "*",
    "phpunit/phpunit": "^9.6",
    "squizlabs/php_codesniffer": "^3.7",
    "silverstripe/standards": "^1",
    "phpstan/extension-installer": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "Sunnysideup\\CybersourceUnifiedCheckout\\": "src/"
    }
  },
  "extra": {
    "expose": [
      "client/dist"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "bin": [
    "bin/sake-npm-build-cybersource-unified-checkout.sh",
    "bin/sake-npm-watch-cybersource-unified-checkout.sh"
  ],
  "authors": [
    {
      "name": "Nicolaas Thiemen Francken",
      "email": "modules@sunnysideup.co.nz",
      "role": "lead developer"
    }
  ]
}
